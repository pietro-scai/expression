      "mermaid": "graph TD\n    entertainment([entertainment])\n    expense_inflation([expense_inflation])\n    groceries([groceries])\n    housing_cost([housing_cost])\n    tax_rate([tax_rate])\n    transport([transport])\n    utilities([utilities])\n    salary[/salary/]\n    cumulative_savings[cumulative_savings]\n    gross_income[gross_income]\n    net_income[net_income]\n    net_savings[net_savings]\n    savings_rate[savings_rate]\n    taxes[taxes]\n    total_expenses[total_expenses]\n    salary --> gross_income\n    gross_income --> taxes\n    tax_rate --> taxes\n    gross_income --> net_income\n    taxes --> net_income\n    entertainment --> total_expenses\n    expense_inflation --> total_expenses\n    groceries --> total_expenses\n    housing_cost --> total_expenses\n    transport --> total_expenses\n    utilities --> total_expenses\n    net_income --> net_savings\n    total_expenses --> net_savings\n    net_income --> savings_rate\n    net_savings --> savings_rate\n    net_savings --> cumulative_savings"
