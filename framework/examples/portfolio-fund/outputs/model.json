      "mermaid": "graph TD\n    fund_size([fund_size])\n    n_cos([n_cos])\n    pct_y1([pct_y1])\n    pct_y2([pct_y2])\n    pct_y3([pct_y3])\n    COMPANIES([COMPANIES])\n    EXIT_MAP([EXIT_MAP])\n    MOIC_MAP([MOIC_MAP])\n    distribution[distribution]\n    drawdown[drawdown]\n    irr_pct[irr_pct]\n    moic_at_exit[moic_at_exit]\n    total_distribution[total_distribution]\n    total_drawdown[total_drawdown]\n    fund_size --> drawdown\n    n_cos --> drawdown\n    pct_y1 --> drawdown\n    pct_y2 --> drawdown\n    pct_y3 --> drawdown\n    EXIT_MAP --> distribution\n    MOIC_MAP --> distribution\n    fund_size --> distribution\n    n_cos --> distribution\n    EXIT_MAP --> moic_at_exit\n    MOIC_MAP --> moic_at_exit\n    EXIT_MAP --> irr_pct\n    MOIC_MAP --> irr_pct\n    fund_size --> irr_pct\n    n_cos --> irr_pct\n    pct_y1 --> irr_pct\n    pct_y2 --> irr_pct\n    pct_y3 --> irr_pct\n    fund_size --> total_drawdown\n    pct_y1 --> total_drawdown\n    pct_y2 --> total_drawdown\n    pct_y3 --> total_drawdown\n    COMPANIES --> total_distribution\n    EXIT_MAP --> total_distribution\n    MOIC_MAP --> total_distribution\n    fund_size --> total_distribution\n    n_cos --> total_distribution"
    },
    {
      "name": "FundModel",
      "doc": "Fund-level simulation: fees, NAV, cumulative MOIC and IRR.",
      "axes": {
        "time": {
          "kind": "periods",
          "values": [
            2025,
            2026,
            2027,
            2028,
            2029,
            2030,
            2031,
            2032,
            2033,
            2034
          ]
        }
      },
      "globals": {
        "fund_size": {
          "default": 35000,
          "type": "int",
          "doc": "Total fund size ($M)"
        },
        "mgmt_fee_pct": {
          "default": 0.015,
          "type": "float",
          "doc": "Annual mgmt fee % of committed capital"
        }
      },
      "rows": [
        {
          "name": "drawn",
          "kind": "row",
          "doc": "Capital called from LPs each year ($M).",
          "depends_on": [
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef drawn(self, t):\n    \"\"\"Capital called from LPs each year ($M).\"\"\"\n    return self.portfolio.total_drawdown(t)\n"
        },
        {
          "name": "distributed",
          "kind": "row",
          "doc": "Cash returned to LPs each year ($M).",
          "depends_on": [
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef distributed(self, t):\n    \"\"\"Cash returned to LPs each year ($M).\"\"\"\n    return self.portfolio.total_distribution(t)\n"
        },
        {
          "name": "mgmt_fee",
          "kind": "row",
          "doc": "Annual management fee ($M).",
          "depends_on": [
            "fund_size",
            "mgmt_fee_pct"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef mgmt_fee(self, t):\n    \"\"\"Annual management fee ($M).\"\"\"\n    return self.fund_size * self.mgmt_fee_pct\n"
        },
        {
          "name": "net_cf",
          "kind": "row",
          "doc": "Net fund cash flow after fees ($M). Negative = LP outflow.",
          "depends_on": [
            "fund_size",
            "mgmt_fee_pct",
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef net_cf(self, t):\n    \"\"\"Net fund cash flow after fees ($M). Negative = LP outflow.\"\"\"\n    return (\n        self.portfolio.total_distribution(t)\n        - self.portfolio.total_drawdown(t)\n        - self.fund_size * self.mgmt_fee_pct\n    )\n"
        },
        {
          "name": "cum_drawn",
          "kind": "row",
          "doc": "Cumulative capital called ($M).",
          "depends_on": [
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef cum_drawn(self, t):\n    \"\"\"Cumulative capital called ($M).\"\"\"\n    return sum(self.portfolio.total_drawdown(yr) for yr in range(2025, t + 1))\n"
        },
        {
          "name": "cum_distributed",
          "kind": "row",
          "doc": "Cumulative distributions ($M).",
          "depends_on": [
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef cum_distributed(self, t):\n    \"\"\"Cumulative distributions ($M).\"\"\"\n    return sum(self.portfolio.total_distribution(yr) for yr in range(2025, t + 1))\n"
        },
        {
          "name": "nav",
          "kind": "row",
          "doc": "NAV = cumulative drawn - cumulative distributed ($M).",
          "depends_on": [
            "cum_distributed",
            "cum_drawn"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef nav(self, t):\n    \"\"\"NAV = cumulative drawn - cumulative distributed ($M).\"\"\"\n    return self.cum_drawn(t) - self.cum_distributed(t)\n"
        },
        {
          "name": "fund_moic",
          "kind": "row",
          "doc": "Cumulative MOIC = total distributed / total drawn.",
          "depends_on": [
            "cum_distributed",
            "cum_drawn"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef fund_moic(self, t):\n    \"\"\"Cumulative MOIC = total distributed / total drawn.\"\"\"\n    cd = self.cum_drawn(t)\n    return round(self.cum_distributed(t) / cd, 2) if cd else 0.0\n"
        },
        {
          "name": "fund_irr",
          "kind": "row",
          "doc": "Fund IRR % on net cash flows to date (0 before first exit in 2029).",
          "depends_on": [
            "fund_size",
            "mgmt_fee_pct",
            "portfolio"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef fund_irr(self, t):\n    \"\"\"Fund IRR % on net cash flows to date (0 before first exit in 2029).\"\"\"\n    if t < 2029:\n        return 0.0\n    flows = [\n        self.portfolio.total_distribution(yr)\n        - self.portfolio.total_drawdown(yr)\n        - self.fund_size * self.mgmt_fee_pct\n        for yr in range(2025, t + 1)\n    ]\n    return _irr(flows)\n"
        }
      ],
      "scalars": [],
