{
  "models": [
    {
      "name": "PortfolioModel",
      "doc": "Per-company drawdown / distribution matrix.",
      "axes": {
        "time": {
          "kind": "periods",
          "values": [
            2025,
            2026,
            2027,
            2028,
            2029,
            2030,
            2031,
            2032,
            2033,
            2034
          ]
        },
        "companies": {
          "kind": "dim",
          "values": [
            "Co1",
            "Co2",
            "Co3",
            "Co4",
            "Co5",
            "Co6",
            "Co7",
            "Co8",
            "Co9",
            "Co10"
          ]
        }
      },
      "globals": {
        "fund_size": {
          "default": 35000,
          "type": "int",
          "doc": "Total fund size ($M)"
        },
        "n_cos": {
          "default": 10,
          "type": "int",
          "doc": "Number of portfolio companies"
        },
        "pct_y1": {
          "default": 0.5,
          "type": "float",
          "doc": "% of commitment called in investment year 1"
        },
        "pct_y2": {
          "default": 0.3,
          "type": "float",
          "doc": "% of commitment called in investment year 2"
        },
        "pct_y3": {
          "default": 0.2,
          "type": "float",
          "doc": "% of commitment called in investment year 3"
        }
      },
      "rows": [
        {
          "name": "drawdown",
          "kind": "row",
          "doc": "Capital called per company ($M). Same J-curve schedule for all.",
          "depends_on": [
            "fund_size",
            "n_cos",
            "pct_y1",
            "pct_y2",
            "pct_y3"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            },
            {
              "kind": "dim",
              "values": [
                "Co1",
                "Co2",
                "Co3",
                "Co4",
                "Co5",
                "Co6",
                "Co7",
                "Co8",
                "Co9",
                "Co10"
              ]
            }
          ],
          "source": "@row(over=[time, companies])\ndef drawdown(self, t, companies):\n    \"\"\"Capital called per company ($M). Same J-curve schedule for all.\"\"\"\n    alloc = self.fund_size / self.n_cos\n    if t == 2025:\n        return alloc * self.pct_y1\n    if t == 2026:\n        return alloc * self.pct_y2\n    if t == 2027:\n        return alloc * self.pct_y3\n    return 0.0\n"
        },
        {
          "name": "distribution",
          "kind": "row",
          "doc": "Cash returned to LP per company at exit ($M).",
          "depends_on": [
            "EXIT_MAP",
            "MOIC_MAP",
            "fund_size",
            "n_cos"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            },
            {
              "kind": "dim",
              "values": [
                "Co1",
                "Co2",
                "Co3",
                "Co4",
                "Co5",
                "Co6",
                "Co7",
                "Co8",
                "Co9",
                "Co10"
              ]
            }
          ],
          "source": "@row(over=[time, companies])\ndef distribution(self, t, companies):\n    \"\"\"Cash returned to LP per company at exit ($M).\"\"\"\n    alloc = self.fund_size / self.n_cos\n    return alloc * MOIC_MAP[companies] if t == EXIT_MAP[companies] else 0.0\n"
        },
        {
          "name": "moic_at_exit",
          "kind": "row",
          "doc": "Exit MOIC shown in exit year, 0 otherwise.",
          "depends_on": [
            "EXIT_MAP",
            "MOIC_MAP"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            },
            {
              "kind": "dim",
              "values": [
                "Co1",
                "Co2",
                "Co3",
                "Co4",
                "Co5",
                "Co6",
                "Co7",
                "Co8",
                "Co9",
                "Co10"
              ]
            }
          ],
          "source": "@row(over=[time, companies])\ndef moic_at_exit(self, t, companies):\n    \"\"\"Exit MOIC shown in exit year, 0 otherwise.\"\"\"\n    return MOIC_MAP[companies] if t == EXIT_MAP[companies] else 0.0\n"
        },
        {
          "name": "irr_pct",
          "kind": "row",
          "doc": "Company IRR % shown in exit year, 0 otherwise.",
          "depends_on": [
            "EXIT_MAP",
            "MOIC_MAP",
            "fund_size",
            "n_cos",
            "pct_y1",
            "pct_y2",
            "pct_y3"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            },
            {
              "kind": "dim",
              "values": [
                "Co1",
                "Co2",
                "Co3",
                "Co4",
                "Co5",
                "Co6",
                "Co7",
                "Co8",
                "Co9",
                "Co10"
              ]
            }
          ],
          "source": "@row(over=[time, companies])\ndef irr_pct(self, t, companies):\n    \"\"\"Company IRR % shown in exit year, 0 otherwise.\"\"\"\n    alloc = self.fund_size / self.n_cos\n    if t != EXIT_MAP[companies]:\n        return 0.0\n    flows = []\n    for yr in range(2025, 2035):\n        cf = 0.0\n        if yr == 2025:\n            cf -= alloc * self.pct_y1\n        if yr == 2026:\n            cf -= alloc * self.pct_y2\n        if yr == 2027:\n            cf -= alloc * self.pct_y3\n        if yr == EXIT_MAP[companies]:\n            cf += alloc * MOIC_MAP[companies]\n        flows.append(cf)\n    return _irr(flows)\n"
        },
        {
          "name": "total_drawdown",
          "kind": "row",
          "doc": "Total drawdown across all companies ($M).",
          "depends_on": [
            "fund_size",
            "pct_y1",
            "pct_y2",
            "pct_y3"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef total_drawdown(self, t):\n    \"\"\"Total drawdown across all companies ($M).\"\"\"\n    if t == 2025:\n        return self.fund_size * self.pct_y1\n    if t == 2026:\n        return self.fund_size * self.pct_y2\n    if t == 2027:\n        return self.fund_size * self.pct_y3\n    return 0.0\n"
        },
        {
          "name": "total_distribution",
          "kind": "row",
          "doc": "Total distributions across all companies ($M).",
          "depends_on": [
            "COMPANIES",
            "EXIT_MAP",
            "MOIC_MAP",
            "fund_size",
            "n_cos"
          ],
          "columns": [
            {
              "kind": "periods",
              "values": [
                2025,
                2026,
                2027,
                2028,
                2029,
                2030,
                2031,
                2032,
                2033,
                2034
              ]
            }
          ],
          "source": "@row\ndef total_distribution(self, t):\n    \"\"\"Total distributions across all companies ($M).\"\"\"\n    alloc = self.fund_size / self.n_cos\n    return sum(alloc * MOIC_MAP[co] for co in COMPANIES if EXIT_MAP[co] == t)\n"
        }
      ],
      "scalars": [],
